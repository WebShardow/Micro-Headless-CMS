generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  date        DateTime
  thumbnail   String?
  gallery     String[] @default([])
  videoLink   String?
  projectUrl  String?
  toolsUsed   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model SiteConfig {
  id              String  @id @default("default")
  siteName        String  @default("Micro Headless CMS")
  domain          String  @default("")
  language        String  @default("th")
  timezone        String  @default("Asia/Bangkok")
  // ── Zone 1: Logo ─────────────────────────────────────
  logoUrl         String  @default("")
  logoAlt         String  @default("Logo")
  showLogoText    Boolean @default(true)
  // ── Zone 1: Navbar ───────────────────────────────────
  navStyle        String  @default("fixed")
  navBgColor      String  @default("#0ea5e9")
  navTextColor    String  @default("#ffffff")
  // ── Zone 1: Hero ─────────────────────────────────────
  showHero        Boolean @default(true)
  heroStyle       String  @default("centered")
  heroHeading     String  @default("สวัสดี ฉันคือนักออกแบบ")
  heroSubheading  String  @default("ดูผลงานสร้างสรรค์ของฉันด้านล่าง")
  heroBgColor     String  @default("#f0f9ff")
  heroTextColor   String  @default("#0f172a")
  heroImageUrl    String  @default("")
  heroBtnLabel    String  @default("ดูผลงาน")

  heroBtnColor    String  @default("#f59e0b")
  // ── Zone 2: Main Content ──────────────────────────────
  primaryColor    String  @default("#0ea5e9")
  accentColor     String  @default("#f59e0b")
  bgColor         String  @default("#f8fafc")
  textColor       String  @default("#1e293b")
  fontFamily      String  @default("Inter")
  layoutStyle     String  @default("grid")
  showSidebar     Boolean @default(false)
  sidebarPosition String  @default("left")
  // ── Zone 3: Footer ────────────────────────────────────
  footerCopyright String  @default("© 2024 My Portfolio")
  footerBgColor   String  @default("#1e293b")
  footerTextColor String  @default("#94a3b8")
  // ── Communication ────────────────────────────────────
  discordUrl      String  @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MenuItem {
  id         String   @id @default(uuid())
  label      String
  url        String
  order      Int      @default(0)
  isExternal    Boolean  @default(false)
  isVisible     Boolean  @default(true)
  showInNavbar  Boolean  @default(true)
  showInSidebar Boolean  @default(false)
  showInFooter  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Page {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @default("")
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}





model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  password           String
  role               String   @default("user")
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String   // image/png, image/jpeg, etc.
  size      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
